# Nova Voice Assistant — Environment Variables
#
# Copy this file to .env and fill in your values.
# DO NOT commit your .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your API keys
#   python main.py

# ── OpenAI ────────────────────────────────────────────────────────────────
# Required for natural language understanding and conversational responses.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Model to use (gpt-4o-mini is fast and affordable, gpt-4o for best quality)
OPENAI_MODEL=gpt-4o-mini

# ── OpenWeatherMap ────────────────────────────────────────────────────────
# Required for weather commands. Free tier available.
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# Default city when none is specified in the command
DEFAULT_CITY=New York

# ── NewsAPI ───────────────────────────────────────────────────────────────
# Required for news headline commands. Free tier available.
# Get your key at: https://newsapi.org/
NEWS_API_KEY=0fb6732870f941788ad89c12ba24aa83

# ── Wake Word ─────────────────────────────────────────────────────────────
WAKE_WORD=nova
WAKE_WORD_ENABLED=true
WAKE_WORD_SENSITIVITY=0.5

# ── Audio Settings ────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=1024
SILENCE_THRESHOLD=500
SILENCE_DURATION=1.5
MAX_RECORD_SECONDS=15

# ── Speech Recognition ────────────────────────────────────────────────────
# Whisper model: tiny | base | small | medium | large
# Smaller = faster, larger = more accurate
WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=en
WHISPER_DEVICE=auto

# ── Text-to-Speech ────────────────────────────────────────────────────────
TTS_RATE=175
TTS_VOLUME=0.9
TTS_VOICE_INDEX=0

# ── GUI ───────────────────────────────────────────────────────────────────
GUI_THEME=dark
GUI_COLOR_THEME=blue
GUI_WIDTH=1100
GUI_HEIGHT=720

# ── Application ───────────────────────────────────────────────────────────
DEBUG=false
DEFAULT_USER_NAME=User
